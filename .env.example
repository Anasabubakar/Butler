# Butler AI OS — Environment Configuration
# Copy to:
#   .env                 (root — docker-compose / backend local)
#   backend/.env         (backend process)
#   frontend/.env.local  (Next.js — NEXT_PUBLIC_* only)

# === Server ===
PORT=8080
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# === PostgreSQL ===
DATABASE_URL=postgres://butler:butler_dev_password@localhost:5432/butler?sslmode=disable
MIGRATIONS_PATH=migrations

# === Gemini AI (server-side only) ===
GEMINI_API_KEY=your_gemini_api_key_here

# === Firebase (Backend — token verification) ===
FIREBASE_PROJECT_ID=your_firebase_project_id

# === Firebase (Frontend — NEXT_PUBLIC_ prefix) ===
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# === Frontend ↔ Backend URLs ===
NEXT_PUBLIC_API_URL=http://localhost:8080
PUBLIC_API_BASE=http://localhost:8080
APP_BASE_URL=http://localhost:3000

# === Token vault (AES-256). Required in production. ===
TOKEN_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# === Workspace / proactive brief ===
# When true, POST /api/workspace/sync creates notifications + draft delegations
ENABLE_PROACTIVE_SYNC=true
# Optional background interval (minutes). 0 = disabled (sync on demand only)
PROACTIVE_SYNC_INTERVAL_MINUTES=0

# === Optional OAuth connectors ===
# Callback for each: {PUBLIC_API_BASE}/api/integrations/callback/{provider}
# See docs/CONNECTORS.md for baby-step setup.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Optional (webhooks/events later; not required for OAuth connect)
SLACK_SIGNING_SECRET=
SLACK_VERIFICATION_TOKEN=

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=
# Optional: https://YOUR_API/api/webhooks/linear (not the frontend host)
LINEAR_DEVELOPER_USER_TOKEN=
LINEAR_DEVELOPER_APP_TOKEN=
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Hex public key from Discord Developer Portal (Interactions Endpoint verification)
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
# Interactions Endpoint URL:
#   {PUBLIC_API_BASE}/api/webhooks/discord
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
TRELLO_API_KEY=
TRELLO_API_SECRET=
# Defaults to PUBLIC_API_BASE
# OAUTH_REDIRECT_BASE=https://api.yourdomain.com
